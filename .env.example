# Copy this file to .env and fill in real values before running the app.
# This file is a TEMPLATE committed to git — never put real secrets here.

# PostgreSQL connection string. Managed providers (Neon, Supabase, Render...)
# require SSL, which src/db/index.ts enables automatically unless the host
# is localhost/127.0.0.1.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign both user session and admin JWTs. Generate a long
# random value, e.g.: openssl rand -base64 32
JWT_SECRET=

# Shared password for the /admin dashboard. Leaving this unset disables the
# admin area entirely (fails closed, never open by default).
ADMIN_PASSWORD=

# Loyalty points: how many points are earned per whole MAD spent, and how
# many MAD (in cents) one redeemed point is worth at checkout. Optional —
# both default to sensible values in src/lib/points.ts if unset.
POINTS_PER_MAD=1
MAD_CENTS_PER_POINT=10

# Store's WhatsApp number in international format, no "+" or spaces (e.g.
# 212612345678). NEXT_PUBLIC_ because the wa.me link is built client-side;
# the number is public by nature. Leaving this unset hides all WhatsApp
# buttons instead of showing a broken link.
NEXT_PUBLIC_WHATSAPP_NUMBER=212XXXXXXXXX

# Public base URL of the deployed site, used for metadataBase (Open Graph
# images, canonical URLs) and the sitemap. Use your real domain in
# production.
NEXT_PUBLIC_SITE_URL=https://your-site.example
